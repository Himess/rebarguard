# === LLM RUNTIME ===
# "cli"    = all calls route through `hermes` CLI, covered by Nous Portal subscription ($0 Kimi).
# "direct" = our OpenAI-compat clients call Nous Portal / Moonshot directly (paid).
# "sdk"    = import hermes_agent Python SDK directly (not implemented yet).
HERMES_RUNTIME=cli

# Windows-only: invoke hermes via WSL2
HERMES_CLI_VIA_WSL=true
HERMES_WSL_DISTRO=Ubuntu-22.04
HERMES_CLI_TIMEOUT_S=120
HERMES_CLI_MAX_TURNS=3

# === NOUS PORTAL (only needed when HERMES_RUNTIME=direct) ===
# Subscribe at https://portal.nousresearch.com — the $10/mo plan covers the `cli` runtime
# above and Nous Chat, but does NOT cover direct API usage.
NOUS_PORTAL_API_KEY=
NOUS_PORTAL_BASE_URL=https://api.portal.nousresearch.com/v1
HERMES_AGENTIC_MODEL=moonshotai/kimi-k2.6
HERMES_REASONING_MODEL=Hermes-4-70B

# === MOONSHOT DIRECT (vision fallback only) ===
# Used if VISION_BACKEND=moonshot and the Hermes Agent framework can't carry images.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
KIMI_VISION_MODEL=kimi-k2.6

# "nous_portal" | "moonshot" | "hermes_cli"
VISION_BACKEND=nous_portal

# === SUPABASE (Day 11+) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# === EXTERNAL ===
AFAD_API_BASE=https://tdth.afad.gov.tr

# === APP ===
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000
