# Nous Portal — primary API (user has subscription)
# Kimi K2.5 is $0/1M on Nous Portal — use as the agentic model AND vision model if it supports multimodal
NOUS_PORTAL_API_KEY=
NOUS_PORTAL_BASE_URL=https://api.portal.nousresearch.com/v1
HERMES_AGENTIC_MODEL=moonshotai/kimi-k2.5
HERMES_REASONING_MODEL=Hermes-4-70B

# Moonshot — fallback / direct vision (leave empty to use Nous Portal for vision too)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
KIMI_VISION_MODEL=kimi-k2.5

# Which backend handles vision: "nous_portal" or "moonshot"
VISION_BACKEND=nous_portal

# Supabase (Day 11+)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# AFAD (seismic zone lookups)
AFAD_API_BASE=https://tdth.afad.gov.tr

# App
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000
